# Language: "auto" or a code like "de", "en", "fr"
LANGUAGE=auto

# Model: tiny, base, small, medium, large-v2, large-v3
MODEL_SIZE=large-v3

# GPU
DEVICE=cuda
COMPUTE_TYPE=float16

# Beam search width (higher = slightly better, slower)
BEAM_SIZE=10

# Optional: prime the model with context / domain vocabulary
INITIAL_PROMPT=Funkverkehr im DMR-Digitalnetz mit Rufzeichen und Kanalnamen.

# Optional: comma-separated words to bias decoding towards (e.g. call signs)
HOTWORDS=

# Thresholds for the "nothing understood" detection
NO_SPEECH_THRESHOLD=0.6
LOGPROB_THRESHOLD=-1.0

# Database
DB_FILE=transcriptions.db